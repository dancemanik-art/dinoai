# OpenAI — povinné pro funkční AI chat
OPENAI_API_KEY=sk-...

# Volitelné — výchozí model je gpt-4.1-mini (levný provoz)
# OPENAI_MODEL=gpt-4.1-mini

# Volitelné — max. délka odpovědi v tokenech (výchozí 450, strop 800)
# OPENAI_MAX_TOKENS=450

# Drahé modely (gpt-4.1, gpt-5, …) jen s explicitním povolením:
# OPENAI_ALLOW_EXPENSIVE_MODEL=true
# OPENAI_MODEL=gpt-4.1
